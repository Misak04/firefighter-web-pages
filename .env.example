NODE_ENV=development
PORT=3000

# PostgreSQL
POSTGRES_USER=firefighter
POSTGRES_PASSWORD=change-me
POSTGRES_DB=firefighter
DATABASE_URL=postgresql://firefighter:change-me@postgres:5432/firefighter

# Redis
REDIS_PASSWORD=change-me
REDIS_URL=redis://:change-me@redis:6379

# JWT (min 32 chars)
JWT_ACCESS_SECRET=change-me-to-a-random-32-char-secret
JWT_REFRESH_SECRET=change-me-to-a-different-32-char-secret

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=change-me
MINIO_BUCKET=gallery
