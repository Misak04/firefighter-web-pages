// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  EDITOR
  VIEWER
}

model User {
  id           String     @id @default(uuid())
  email        String     @unique
  passwordHash String
  role         Role       @default(VIEWER)
  createdAt    DateTime   @default(now())
  lastLogin    DateTime?
  auditLogs    AuditLog[]
  articles     Article[]
  media        Media[]
}

enum ArticleStatus {
  DRAFT
  PUBLISHED
}

model Article {
  id              String                @id @default(uuid())
  title           String
  slug            String                @unique
  body            String
  status          ArticleStatus         @default(DRAFT)
  authorId        String
  author          User                  @relation(fields: [authorId], references: [id])
  publishedAt     DateTime?
  featuredImageId String?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  searchVector    Unsupported("tsvector")?

  @@index([status, publishedAt])
}

model AuditLog {
  id        String   @id @default(uuid())
  action    String
  success   Boolean
  ip        String?
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}

model Media {
  id             String   @id @default(uuid())
  filename       String
  originalKey    String
  thumbSmallKey  String
  thumbMediumKey String
  size           Int
  mimeType       String
  uploadedById   String
  uploadedBy     User     @relation(fields: [uploadedById], references: [id])
  createdAt      DateTime @default(now())
  photo          Photo?
}

model Event {
  id           String   @id @default(uuid())
  name         String
  year         Int
  description  String?
  coverPhotoId String?  @unique
  coverPhoto   Photo?   @relation("EventCoverPhoto", fields: [coverPhotoId], references: [id])
  photos       Photo[]  @relation("EventPhotos")
  createdAt    DateTime @default(now())

  @@index([year])
}

model Photo {
  id           String   @id @default(uuid())
  mediaId      String   @unique
  media        Media    @relation(fields: [mediaId], references: [id])
  eventId      String
  event        Event    @relation("EventPhotos", fields: [eventId], references: [id])
  title        String?
  sortOrder    Int      @default(0)
  coverOfEvent Event?   @relation("EventCoverPhoto")
  createdAt    DateTime @default(now())

  @@index([eventId, sortOrder])
}
